Example1 -
  public class Car{
    private String color;
    private int speed;

    //constructor
    public Car(String c , int s){
        this.color = c ;
        this.speed = s ;
    }

    //method for info
    public void info(){
        System.out.println("Color of Car:" + color);
        System.out.println("Speed of Car:" + speed);
    }


    public static void main(String[] args){
        Car c1 = new Car("Red", 120);
        c1.info();
    }
}

    

