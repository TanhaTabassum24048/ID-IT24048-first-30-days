  public class Student{
    private String dept;
    private int ID;

    //constructor
    public Student(String dept , int id){
        this.dept = dept ;
        this.ID = id ;
    }

    //method for info
    public void info(){
        System.out.println("Department of Student:" + dept);
        System.out.println("ID of student:" + ID);
    }


    public static void main(String[] args){
        Student s1 = new Student("ICT", 24002);
        s1.info();
    }
}

    
