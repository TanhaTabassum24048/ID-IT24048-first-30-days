import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;

public class HospitalAppointment {
    public static void main(String[] args) {
        LocalDateTime appointmentTime = LocalDateTime.now();

        DateTimeFormatter formatter =
                DateTimeFormatter.ofPattern("dd MMM yyyy hh:mm a");

        String formattedAppointment = appointmentTime.format(formatter);

        System.out.println("Appointment Confirmed!");
        System.out.println("Patient: Montu Mia");
        System.out.println("Doctor: Dr. Kuddus");
        System.out.println("Appointment Date & Time: " + formattedAppointment);
    }
}


