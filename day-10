import java.util.*;

public class MainQueue {
    public static void main(String[] args) {

        Queue<String> queue = new LinkedList<>();

        queue.add("Ali");
        queue.add("Rahim");
        queue.add("Karim");
        queue.add("Sakib");
        queue.add("Nadia");

        System.out.println("Initial Queue: " + queue);

        queue.poll();
        queue.poll();

        System.out.println("After removing 2 students: " + queue);
        System.out.println("Front student: " + queue.peek());
        System.out.println("Final Queue: " + queue);
    }
}


