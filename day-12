//java collection framework real world scenario(queue- ticket counterline)
import java.util.*;

public class Ticket {
    public static void main(String[] args) {
        Queue<String> q = new LinkedList<>();

        q.add("Customer 1");
        q.add("Customer 2");
        q.add("Customer 3");

        System.out.println("Serving: " + q.poll());
        System.out.println(q);
    }
} 
    



