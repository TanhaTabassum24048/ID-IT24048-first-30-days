  import java.time.ZonedDateTime;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

public class TMZone {
    public static void main(String[] args) {
        ZonedDateTime dhakaTime = ZonedDateTime.now(ZoneId.of("Asia/Dhaka"));

        ZonedDateTime newYorkTime =
                ZonedDateTime.now(ZoneId.of("America/New_York"));

        DateTimeFormatter formatter =
                DateTimeFormatter.ofPattern("dd MMM yyyy hh:mm a z");

        System.out.println("Dhaka Time: " + dhakaTime.format(formatter));
        System.out.println("New York Time: " + newYorkTime.format(formatter));
    }
}

